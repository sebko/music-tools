# Music Recognition APIs
# ======================

# RapidAPI Shazam
# Get API key at: https://rapidapi.com/apidojo/api/shazam
RAPIDAPI_SHAZAM_KEY=your_rapidapi_shazam_key_here
RAPIDAPI_SHAZAM_HOST=shazam.p.rapidapi.com

# AudD API
# Get API key at: https://audd.io/
AUDD_API_KEY=your_audd_api_key_here

# ACRCloud API
# Get credentials at: https://www.acrcloud.com/
ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
ACRCLOUD_ACCESS_KEY=your_acrcloud_access_key_here
ACRCLOUD_ACCESS_SECRET=your_acrcloud_access_secret_here

# Music Recognition Configuration
RECOGNITION_CONSENSUS_THRESHOLD=0.7
RECOGNITION_TIMEOUT_MS=30000