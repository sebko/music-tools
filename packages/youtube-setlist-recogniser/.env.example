# YouTube Data API v3
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=

# Anthropic Claude API (for AI-powered comment extraction)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Music Recognition APIs (for audio fingerprinting)
# At least one is recommended for hybrid recognition
RAPIDAPI_SHAZAM_KEY=
AUDD_API_KEY=
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=
ACRCLOUD_HOST=

# Processing Configuration
AUDIO_TEMP_DIR=./temp
MAX_SETLIST_LENGTH=7200  # Maximum video duration in seconds (2 hours)
AUDIO_QUALITY=128        # Audio quality for downloads